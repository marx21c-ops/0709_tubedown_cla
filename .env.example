# --- core ---
PORT=3000
REDIS_URL=redis://127.0.0.1:6379
DOWNLOAD_DIR=./downloads
YTDLP_PATH=yt-dlp

# --- worker tuning ---
WORKER_CONCURRENCY=2
CONCURRENT_FRAGMENTS=8
JOB_TIMEOUT_MS=1800000
MAX_FILESIZE_MB=4096
RETENTION_MINUTES=60

# --- making YouTube actually work in 2026 ---
# PO token provider. docker-compose starts one at http://bgutil:4416
POT_PROVIDER_URL=
# Netscape-format cookies exported from a logged-in browser. Required for
# age-restricted / members-only content, and it raises your rate limits.
COOKIES_FILE=
# Datacenter IPs (Railway, AWS, GCP) get blocked by YouTube. A residential
# proxy is usually the only real fix. Leave empty when running from home.
PROXY_URL=

# --- object storage (leave S3_BUCKET empty to serve from local disk) ---
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
S3_PRESIGN_EXPIRY=3600
